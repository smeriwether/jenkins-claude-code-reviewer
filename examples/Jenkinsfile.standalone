/**
 * Standalone Jenkinsfile — no Shared Library required.
 *
 * Copy this file + scripts/review.py into your repo.
 * Useful if you don't want to set up a Jenkins Shared Library.
 *
 * Prerequisites:
 *   1. Create Jenkins credentials:
 *      - 'gitlab-token'      → Secret text (GitLab PAT with api scope)
 *      - 'aws-bedrock-creds' → Username/Password (AWS access key / secret key)
 *   2. Ensure Claude models are enabled in your AWS Bedrock account.
 *   3. Place scripts/review.py in your repo (or adjust the path below).
 *   4. Set GITLAB_PROJECT_ID and MR_IID as pipeline parameters or env vars.
 */

pipeline {
    agent {
        docker {
            image 'node:20-slim'
            args '--entrypoint=""'
        }
    }

    options {
        timeout(time: 10, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        CLAUDE_CODE_USE_BEDROCK = '1'
        AWS_REGION = 'us-east-1'
        // For self-hosted GitLab, override:
        // GITLAB_API_URL = 'https://gitlab.example.com/api/v4'
    }

    stages {
        stage('Install Claude Code') {
            when {
                expression {
                    env.gitlabMergeRequestIid != null ||
                    env.MR_IID != null ||
                    env.CHANGE_ID != null
                }
            }
            steps {
                sh '''
                    npm install -g @anthropic-ai/claude-code
                    claude --version
                '''
            }
        }

        stage('Run Review') {
            when {
                expression {
                    env.gitlabMergeRequestIid != null ||
                    env.MR_IID != null ||
                    env.CHANGE_ID != null
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'gitlab-token', variable: 'GITLAB_TOKEN'),
                    usernamePassword(
                        credentialsId: 'aws-bedrock-creds',
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                    )
                ]) {
                    script {
                        // Derive MR IID from Jenkins env
                        def mrIid = env.gitlabMergeRequestIid ?:
                                    env.MR_IID ?:
                                    env.CHANGE_ID ?: ''
                        def projectId = env.gitlabMergeRequestTargetProjectId ?:
                                        env.GITLAB_PROJECT_ID ?: ''

                        if (!projectId || !mrIid) {
                            echo 'Not an MR build or missing GITLAB_PROJECT_ID — skipping review.'
                            return
                        }

                        withEnv([
                            "GITLAB_PROJECT_ID=${projectId}",
                            "MR_IID=${mrIid}",
                        ]) {
                            sh 'python3 scripts/review.py'
                        }
                    }
                }
            }
        }
    }

    post {
        failure {
            echo 'Claude Code review failed. Check the console output for details.'
        }
    }
}

/**
 * Standalone Jenkinsfile — no Shared Library required.
 *
 * Copy this file + scripts/review.py into your repo.
 * Useful if you don't want to set up a Jenkins Shared Library.
 *
 * Prerequisites:
 *   1. Create Jenkins credentials:
 *      - 'github-token' -> Secret text (GitHub PAT with repo scope)
 *   2. Ensure Claude models are enabled in your AWS Bedrock account.
 *   3. Place scripts/review.py in your repo (or adjust the path below).
 *   4. Set GITHUB_REPO and PR_NUMBER as pipeline parameters or env vars,
 *      or use a multibranch pipeline (CHANGE_ID is auto-detected).
 */

pipeline {
    agent {
        docker {
            image 'node:20-slim'
            args '--entrypoint=""'
        }
    }

    options {
        timeout(time: 10, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        CLAUDE_CODE_USE_BEDROCK = '1'
        AWS_REGION = 'us-east-1'
        // For GitHub Enterprise Server, override:
        // GITHUB_API_URL = 'https://github.example.com/api/v3'
    }

    stages {
        stage('Install Claude Code') {
            when {
                expression {
                    env.CHANGE_ID != null ||
                    env.ghprbPullId != null ||
                    env.GITHUB_PR_NUMBER != null
                }
            }
            steps {
                sh '''
                    apt-get update
                    apt-get install -y --no-install-recommends python3 ca-certificates git curl
                    rm -rf /var/lib/apt/lists/*

                    npm install -g @anthropic-ai/claude-code
                    claude --version
                '''
            }
        }

        stage('Run Review') {
            when {
                expression {
                    env.CHANGE_ID != null ||
                    env.ghprbPullId != null ||
                    env.GITHUB_PR_NUMBER != null
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'github-token', variable: 'GITHUB_TOKEN')
                ]) {
                    script {
                        // Derive PR number from Jenkins env
                        def prNumber = env.CHANGE_ID ?:
                                       env.ghprbPullId ?:
                                       env.GITHUB_PR_NUMBER ?: ''

                        // Auto-detect repo from GIT_URL
                        def githubRepo = env.GITHUB_REPO ?: ''
                        if (!githubRepo && env.GIT_URL) {
                            def matcher = env.GIT_URL =~ /github\.com[:\\/]([^\\/]+\/[^\\/]+?)(?:\.git)?$/
                            if (matcher.find()) {
                                githubRepo = matcher.group(1)
                            }
                        }

                        if (!githubRepo || !prNumber) {
                            echo 'Not a PR build or missing GITHUB_REPO — skipping review.'
                            return
                        }

                        withEnv([
                            "GITHUB_REPO=${githubRepo}",
                            "PR_NUMBER=${prNumber}",
                        ]) {
                            sh 'python3 scripts/review.py'
                        }
                    }
                }
            }
        }
    }

    post {
        failure {
            echo 'Claude Code review failed. Check the console output for details.'
        }
    }
}

/**
 * Example Jenkinsfile — drop this into any repo to enable Claude Code PR reviews on GitHub.
 *
 * Supports both automatic (multibranch PR builds) and manual triggering via "Build with Parameters".
 *
 * Prerequisites:
 *   1. Add this repo as a Jenkins Shared Library named "claude-code-reviewer"
 *      (Manage Jenkins -> System -> Global Pipeline Libraries)
 *   2. Create Jenkins credentials:
 *      - 'github-token'      -> Secret text (GitHub PAT with repo scope)
 *      - 'aws-bedrock-creds' -> Username/Password (AWS access key ID / secret access key)
 *   3. Ensure Claude models are enabled in your AWS Bedrock account.
 */

@Library('claude-code-reviewer') _

pipeline {
    agent any

    parameters {
        string(name: 'PR_NUMBER', defaultValue: '', description: 'Pull request number to review (leave blank for auto-detection)')
        string(name: 'GITHUB_REPO', defaultValue: '', description: 'GitHub repo as owner/repo (leave blank for auto-detection from GIT_URL)')
    }

    options {
        timeout(time: 10, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Claude Code Review') {
            when {
                expression {
                    params.PR_NUMBER ||
                    env.CHANGE_ID != null ||
                    env.ghprbPullId != null ||
                    env.GITHUB_PR_NUMBER != null
                }
            }
            steps {
                claudeReview(
                    githubTokenCredentialsId: 'github-token',
                    awsCredentialsId: 'aws-bedrock-creds',
                    awsRegion: 'us-east-1',
                    prNumber: params.PR_NUMBER ?: '',
                    githubRepo: params.GITHUB_REPO ?: '',

                    // Optional: Bedrock inference profile or model ID
                    // bedrockInferenceProfile: 'arn:aws:bedrock:us-east-1:123456789012:inference-profile/your-profile',

                    // Optional: GitHub Enterprise Server
                    // githubApiUrl: 'https://github.example.com/api/v3',

                    // Optional overrides:
                    // includePatterns: '*.py,*.js,*.ts,*.go,*.java',
                    // excludePatterns: '*.lock,*.min.js,package-lock.json',
                    // maxDiffSize: '150000',
                    // failOnFindings: false,
                )
            }
        }
    }

    post {
        failure {
            echo 'Claude Code review failed. Check the console output for details.'
        }
    }
}

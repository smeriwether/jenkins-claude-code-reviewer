/**
 * Example Jenkinsfile — drop this into any repo to enable Claude Code PR reviews.
 *
 * Prerequisites:
 *   1. Add this repo as a Jenkins Shared Library named "claude-code-reviewer"
 *      (Manage Jenkins → System → Global Pipeline Libraries)
 *   2. Create Jenkins credentials:
 *      - 'github-token'      → Secret text (GitHub PAT with repo scope)
 *      - 'aws-bedrock-creds' → Username/Password (AWS access key / secret key)
 *   3. Ensure Claude models are enabled in your AWS Bedrock account.
 *
 * The pipeline runs only on pull request builds (CHANGE_ID is set by the
 * GitHub Branch Source plugin).
 */

@Library('claude-code-reviewer') _

pipeline {
    agent any

    options {
        timeout(time: 10, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Claude Code Review') {
            when {
                expression { env.CHANGE_ID != null }
            }
            steps {
                claudeReview(
                    awsCredentialsId: 'aws-bedrock-creds',
                    githubTokenCredentialsId: 'github-token',
                    awsRegion: 'us-east-1',

                    // Optional overrides:
                    // claudeModel: 'us.anthropic.claude-sonnet-4-6',
                    // includePatterns: '*.py,*.js,*.ts,*.go,*.java',
                    // excludePatterns: '*.lock,*.min.js,package-lock.json',
                    // maxDiffSize: '150000',
                    // reviewEvent: 'COMMENT',
                    // failOnFindings: false,
                )
            }
        }
    }

    post {
        failure {
            echo 'Claude Code review failed. Check the console output for details.'
        }
    }
}
